{
  "name": "ovargas/fluentrules",
  "description": "An expressive, type-safe fluent validation rules interface for Yii2 Framework.",
  "keywords": ["yii2", "validator", "fluent", "rules", "validation", "type-safe"],
  "type": "library",
  "license": "proprietary",
  "authors": [
    {
      "name": "Omar R. Vargas R.",
      "role": "Developer",
      "email": "ovargas.dev@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2.0",
    "yiisoft/yii2": "~2.0.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.11"
  },
  "autoload": {
    "psr-4": {
      "ovargas\\fluentrules\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ovargas\\fluentrules\\tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  }
}
